{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Spec/schemas/conflict.schema.json",
  "title": "Conflict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "conflict_id",
    "conflict_type",
    "severity",
    "summary"
  ],
  "properties": {
    "conflict_id": {
      "type": "string",
      "minLength": 1
    },
    "conflict_type": {
      "type": "string",
      "enum": [
        "scope_conflict",
        "relationship_conflict",
        "overlay_conflict",
        "insufficient_grounding",
        "multiple_governing_paths"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "candidate_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relationship_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_scope_dimensions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "edition",
          "jurisdiction",
          "location",
          "climate_zone",
          "building_class",
          "building_use_context",
          "compliance_path",
          "building_element",
          "construction_form",
          "framing_type",
          "material_context",
          "overlay_context",
          "exception_context"
        ]
      }
    },
    "applies_to_answer_item_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_trace_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resolution_required": {
      "type": "boolean",
      "default": true
    }
  }
}
