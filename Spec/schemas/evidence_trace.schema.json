{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Spec/schemas/evidence_trace.schema.json",
  "title": "EvidenceTrace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "trace_steps",
    "candidate_ids",
    "relationship_ids",
    "span_ids",
    "source_locators",
    "authority_class",
    "replay_context"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/traceStep"
      }
    },
    "candidate_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relationship_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "span_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_locators": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority_class": {
      "type": "string",
      "enum": [
        "xml_authoritative",
        "pdf_grounded",
        "mapping_authoritative",
        "overlay_authoritative",
        "heuristic",
        "manual_override"
      ]
    },
    "replay_context": {
      "$ref": "#/$defs/replayContext"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "traceStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_order",
        "role",
        "locator_kind"
      ],
      "properties": {
        "step_order": {
          "type": "integer",
          "minimum": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "scope_mapping",
            "governing_clause",
            "governing_table",
            "selected_row",
            "selected_cell",
            "note_or_callout",
            "overlay",
            "exception",
            "supporting_definition",
            "final_constraint"
          ]
        },
        "candidate_id": {
          "type": "string"
        },
        "relationship_id": {
          "type": "string"
        },
        "span_id": {
          "type": "string"
        },
        "source_locator": {
          "type": "string"
        },
        "locator_kind": {
          "type": "string",
          "enum": [
            "canonical_id",
            "xml_locator",
            "pdf_locator",
            "mapping_record",
            "overlay_record",
            "query_result"
          ]
        },
        "baseline_vs_overlay": {
          "type": "string",
          "enum": [
            "baseline",
            "overlay",
            "mixed"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "replayContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "corpus_build_id",
        "mapping_pack_version",
        "policy_version"
      ],
      "properties": {
        "corpus_build_id": {
          "type": "string",
          "minLength": 1
        },
        "mapping_pack_version": {
          "type": "string",
          "minLength": 1
        },
        "overlay_bundle_id": {
          "type": "string"
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        },
        "followup_scope_source": {
          "type": "string"
        }
      }
    }
  }
}
