{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XML Source Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validation_id",
    "contract",
    "document",
    "overall_status",
    "gate_decision",
    "confidence",
    "rule_results",
    "warnings",
    "errors",
    "validation_trace",
    "approval"
  ],
  "properties": {
    "validation_id": {
      "type": "string"
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "contract_version"
      ],
      "properties": {
        "contract_id": {
          "type": "string"
        },
        "contract_version": {
          "type": "string"
        }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_id",
        "edition",
        "volume",
        "nodes_processed"
      ],
      "properties": {
        "doc_id": {
          "type": "string"
        },
        "paired_document_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "root_element": {
          "type": "string"
        },
        "schema_family_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "schema_family_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "schema_approved": {
          "type": "boolean"
        },
        "schema_variant_detected": {
          "type": "boolean"
        },
        "unknown_schema_family": {
          "type": "boolean"
        },
        "schema_match_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "schema_match_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schema_parser_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "schema_registry_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "schema_normalizer_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "edition": {
          "type": "string"
        },
        "amendment": {
          "type": [
            "string",
            "null"
          ]
        },
        "volume": {
          "type": "string"
        },
        "section": {
          "type": [
            "string",
            "null"
          ]
        },
        "part": {
          "type": [
            "string",
            "null"
          ]
        },
        "paired_pdf_doc_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "nodes_processed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED",
        "REVIEW_REQUIRED"
      ]
    },
    "gate_decision": {
      "type": "object",
      "description": "Entry gate for alignment compatibility. This schema keeps existing field names while candidate-stage semantics are documented in the higher-level contracts.",
      "additionalProperties": false,
      "required": [
        "can_progress_to_alignment_layer",
        "blocked"
      ],
      "properties": {
        "can_progress_to_alignment_layer": {
          "type": "boolean",
          "description": "When true, the XML may enter alignment processing. This does not by itself authorize candidate extraction, semantic promotion, or direct snippet creation."
        },
        "blocked": {
          "type": "boolean"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall",
        "sources"
      ],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sources": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "rule_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "status",
          "details"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "PASS_WITH_WARNINGS",
              "FAIL"
            ]
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "table_validation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "table_id",
          "status",
          "confidence"
        ],
        "properties": {
          "table_id": {
            "type": "string"
          },
          "fragment_id": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "FAIL"
            ]
          },
          "rows_expected": {
            "type": "integer"
          },
          "rows_extracted": {
            "type": "integer"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "severity",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "warning",
              "info"
            ]
          },
          "rule_id": {
            "type": "string"
          },
          "fragment_id": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "related_fragment_id": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "severity",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "rule_id": {
            "type": "string"
          },
          "fragment_id": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "related_fragment_id": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "validation_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step",
          "status"
        ],
        "properties": {
          "step": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "PASS_WITH_WARNINGS",
              "FAIL"
            ]
          }
        }
      }
    },
    "trace_sample": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "clause_id",
          "status"
        ],
        "properties": {
          "fragment_id": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "clause_id": {
            "type": "string"
          },
          "xml_path": {
            "type": "string"
          },
          "page": {
            "type": "integer"
          },
          "bbox": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "status": {
            "type": "string"
          },
          "related_fragment_id": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved",
        "approved_by_type",
        "approved_at"
      ],
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "approved_by_type": {
          "type": "string",
          "enum": [
            "system",
            "human"
          ]
        },
        "approved_by_id": {
          "type": "string"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "PASS"
          }
        }
      },
      "then": {
        "properties": {
          "gate_decision": {
            "properties": {
              "can_progress_to_alignment_layer": {
                "const": true
              },
              "blocked": {
                "const": false
              }
            }
          },
          "warnings": {
            "maxItems": 0
          },
          "errors": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "PASS_WITH_WARNINGS"
          }
        }
      },
      "then": {
        "properties": {
          "gate_decision": {
            "properties": {
              "can_progress_to_alignment_layer": {
                "const": true
              },
              "blocked": {
                "const": false
              }
            }
          },
          "warnings": {
            "minItems": 1
          },
          "errors": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "REVIEW_REQUIRED"
          }
        }
      },
      "then": {
        "properties": {
          "gate_decision": {
            "properties": {
              "can_progress_to_alignment_layer": {
                "const": false
              },
              "blocked": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_status": {
            "enum": [
              "FAIL",
              "BLOCKED"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "gate_decision": {
            "properties": {
              "can_progress_to_alignment_layer": {
                "const": false
              },
              "blocked": {
                "const": true
              }
            }
          },
          "errors": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "confidence": {
            "properties": {
              "overall": {
                "exclusiveMaximum": 0.95
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "overall_status": {
            "enum": [
              "FAIL",
              "BLOCKED",
              "REVIEW_REQUIRED"
            ]
          },
          "gate_decision": {
            "properties": {
              "can_progress_to_alignment_layer": {
                "const": false
              }
            }
          }
        }
      }
    }
  ]
}