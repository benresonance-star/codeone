{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PDF Ingestion Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validation_id",
    "contract",
    "document",
    "overall_status",
    "gate_decision",
    "confidence",
    "rule_results",
    "alignment_summary",
    "warnings",
    "errors",
    "validation_trace",
    "approval"
  ],

  "properties": {
    "validation_id": {
      "type": "string"
    },

    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_id", "contract_version"],
      "properties": {
        "contract_id": { "type": "string" },
        "contract_version": { "type": "string" }
      }
    },

    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_id", "pages_processed", "fragments_extracted", "tables_extracted"],
      "properties": {
        "doc_id": { "type": "string" },
        "paired_document_id": { "type": ["string", "null"] },
        "paired_xml_doc_id": { "type": ["string", "null"] },
        "pages_processed": { "type": "integer" },
        "fragments_extracted": { "type": "integer" },
        "tables_extracted": { "type": "integer" }
      }
    },

    "overall_status": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED",
        "REVIEW_REQUIRED"
      ]
    },

    "gate_decision": {
      "type": "object",
      "description": "Compatibility gate object for PDF validation. The existing field names are retained while Candidate Extraction becomes the mandatory stage between alignment and semantic promotion.",
      "additionalProperties": false,
      "required": ["can_progress_to_semantic_layer", "blocked"],
      "properties": {
        "can_progress_to_semantic_layer": {
          "type": "boolean",
          "description": "Backward-compatible gate name. When true, validation and alignment evidence are sufficient to enter candidate extraction. Candidate validation and promotion are still required before semantic-layer snippet creation."
        },
        "blocked": { "type": "boolean" },
        "reason": { "type": ["string", "null"] }
      }
    },

    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall", "sources"],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sources": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },

    "rule_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "status", "details"],
        "properties": {
          "rule_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "PASS_WITH_WARNINGS",
              "FAIL"
            ]
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },

    "table_validation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["table_id", "status", "confidence"],
        "properties": {
          "table_id": { "type": "string" },
          "node_id": { "type": "string" },
          "related_xml_node": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL"]
          },
          "rows_expected": { "type": "integer" },
          "rows_extracted": { "type": "integer" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },

    "alignment_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_fragments", "aligned", "unresolved", "average_confidence"],
      "properties": {
        "total_fragments": { "type": "integer" },
        "aligned": { "type": "integer" },
        "unresolved": { "type": "integer" },
        "low_confidence": { "type": "integer" },
        "average_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },

    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["warning", "info"]
          },
          "rule_id": { "type": "string" },
          "fragment_id": { "type": "string" },
          "node_id": { "type": "string" },
          "xml_node": { "type": "string" },
          "message": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },

    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["error"]
          },
          "rule_id": { "type": "string" },
          "fragment_id": { "type": "string" },
          "node_id": { "type": "string" },
          "xml_node": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },

    "validation_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "status"],
        "properties": {
          "step": { "type": "string" },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "PASS_WITH_WARNINGS",
              "FAIL"
            ]
          }
        }
      }
    },

    "trace_sample": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fragment_id", "page", "bbox", "confidence"],
        "properties": {
          "fragment_id": { "type": "string" },
          "node_id": { "type": "string" },
          "xml_node": { "type": "string" },
          "page": { "type": "integer" },
          "bbox": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "anyOf": [
          {
            "required": ["node_id"]
          },
          {
            "required": ["xml_node"]
          }
        ]
      }
    },

    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved", "approved_by_type", "approved_at"],
      "properties": {
        "approved": { "type": "boolean" },
        "approved_by_type": {
          "type": "string",
          "enum": ["system", "human"]
        },
        "approved_by_id": { "type": "string" },
        "approved_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "PASS"
          }
        }
      },
      "then": {
        "properties": {
          "gate_decision": {
            "properties": {
              "can_progress_to_semantic_layer": {
                "const": true
              },
              "blocked": {
                "const": false
              }
            }
          },
          "warnings": {
            "maxItems": 0
          },
          "errors": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "PASS_WITH_WARNINGS"
          }
        }
      },
      "then": {
        "properties": {
          "gate_decision": {
            "properties": {
              "can_progress_to_semantic_layer": {
                "const": true
              },
              "blocked": {
                "const": false
              }
            }
          },
          "warnings": {
            "minItems": 1
          },
          "errors": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "REVIEW_REQUIRED"
          }
        }
      },
      "then": {
        "properties": {
          "gate_decision": {
            "properties": {
              "can_progress_to_semantic_layer": {
                "const": false
              },
              "blocked": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_status": {
            "enum": [
              "FAIL",
              "BLOCKED"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "gate_decision": {
            "properties": {
              "can_progress_to_semantic_layer": {
                "const": false
              },
              "blocked": {
                "const": true
              }
            }
          },
          "errors": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "confidence": {
            "properties": {
              "overall": {
                "exclusiveMaximum": 0.95
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "overall_status": {
            "enum": [
              "FAIL",
              "BLOCKED",
              "REVIEW_REQUIRED"
            ]
          },
          "gate_decision": {
            "properties": {
              "can_progress_to_semantic_layer": {
                "const": false
              }
            }
          }
        }
      }
    }
  ]
}

